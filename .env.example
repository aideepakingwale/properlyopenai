# Copy to server/.env (or root .env — server loads both)

# Required for live AI features. Leave empty to use MOCK_MODE.
OPENAI_API_KEY=

# Force mock responses even if a key is present (true/false)
MOCK_MODE=false

# Server
PORT=3001
# Comma-separated origins, or * for same-origin / public demo deploys
CLIENT_ORIGIN=http://localhost:5173
# Serve client/dist from the API process (recommended for single-service cloud deploy)
SERVE_CLIENT=true

# Assessment
JACCARD_THRESHOLD=0.55
TTS_VOICE=nova

# Storage paths (relative to server/)
STORAGE_DIR=storage
DB_PATH=data/properly.db
