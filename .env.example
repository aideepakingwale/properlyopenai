# Copy to server/.env (or root .env — server loads both)

# Required for live AI features. Leave empty for no OpenAI API spend.
OPENAI_API_KEY=

# Chat model for story generation, coaching, and transcript refinement.
# OpenAI Build Week requires projects to use GPT-5.6.
OPENAI_CHAT_MODEL=gpt-5.6

# Force local/mock story and coach responses even if a key is present (true/false).
MOCK_MODE=false

# Server
PORT=3001
# Comma-separated origins, or * for same-origin / public demo deploys
CLIENT_ORIGIN=http://localhost:5173
# Serve client/dist from the API process (recommended for single-service cloud deploy)
SERVE_CLIENT=true

# Assessment
JACCARD_THRESHOLD=0.55
TTS_VOICE=nova

# Story illustrations.
# Uses metered OpenAI image generation when OPENAI_API_KEY is present and enabled.
# Set ILLUSTRATIONS_ENABLED=false for no image API spend.
ILLUSTRATIONS_ENABLED=true
ILLUSTRATION_MODEL=gpt-image-1-mini
ILLUSTRATION_QUALITY=low
ILLUSTRATION_FORMAT=webp
ILLUSTRATION_COMPRESSION=70

# Storage paths (relative to server/)
STORAGE_DIR=storage
DB_PATH=data/properly.db
